{
	"name": "8th-wall-agent",
	"displayName": "%extension.displayName%",
	"description": "%extension.description%",
	"publisher": "8th-wall",
	"version": "0.7.4",
	"icon": "assets/icons/infin8-purple.png",
	"galleryBanner": {
		"color": "#FFFFFF",
		"theme": "light"
	},
	"engines": {
		"vscode": "^1.84.0",
		"node": "20.19.2"
	},
	"author": {
		"name": "8th Wall"
	},
	"homepage": "https://8thwall.com",
	"categories": [
		"AI",
		"Chat",
		"Programming Languages",
		"Education",
		"Snippets",
		"Testing"
	],
	"keywords": [
		"cline",
		"claude",
		"dev",
		"mcp",
		"openrouter",
		"coding",
		"agent",
		"autonomous",
		"chatgpt",
		"sonnet",
		"ai",
		"llama",
		"Kilo Code",
		"kilocode",
		"roo code",
		"roocode"
	],
	"activationEvents": [
		"onLanguage",
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"walkthroughs": [
			{
				"id": "8thWallAgentWalkthrough",
				"title": "Get Started with 8th Wall Agent",
				"description": "The Game Engine for the AI Era",
				"steps": [
					{
						"id": "desktop",
						"title": "Open Your Project",
						"description": "The same 8th Wall Studio you know and love, now available for Desktop. Faster builds, local files, totally free to develop and host.",
						"media": {
							"markdown": "./dist/walkthrough/step1.md"
						}
					},
					{
						"id": "project",
						"title": "Open a project",
						"description": "From 8th Wall Desktop, open an existing project or create a new one. Then open the same project in VS Code by clicking **Open Externally**.",
						"media": {
							"markdown": "./dist/walkthrough/step2.md"
						},
						"content": {
							"path": "./dist/walkthrough/step2.md"
						}
					},
					{
						"id": "prompt",
						"title": "Ask Agent to Write Code or Modify Your Scene",
						"description": "Use natural language to describe what you want to build, and 8th Wall Agent will write code files and create scene entities as needed to fulfill your request.",
						"media": {
							"markdown": "./dist/walkthrough/step3.md"
						}
					},
					{
						"id": "modes",
						"title": "8th Wall Agent Modes",
						"description": "Choose a mode depending on your task.",
						"media": {
							"markdown": "./dist/walkthrough/step4.md"
						}
					}
				]
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "8th-wall-agent-ActivityBar",
					"title": "%views.activitybar.title%",
					"icon": "assets/icons/infin8-black.png",
					"darkIcon": "assets/icons/infin8-white.png",
					"when": "isMac"
				}
			]
		},
		"views": {
			"8th-wall-agent-ActivityBar": [
				{
					"type": "webview",
					"id": "8th-wall-agent.SidebarProvider",
					"name": "%views.sidebar.name%",
					"icon": "assets/icons/infin8-black.png",
					"darkIcon": "assets/icons/infin8-white.png"
				}
			]
		},
		"commands": [
			{
				"command": "8th-wall-agent.plusButtonClicked",
				"title": "%command.newTask.title%",
				"icon": "$(add)"
			},
			{
				"command": "8th-wall-agent.historyButtonClicked",
				"title": "%command.history.title%",
				"icon": "$(history)"
			},
			{
				"command": "8th-wall-agent.settingsButtonClicked",
				"title": "%command.settings.title%",
				"icon": "$(settings-gear)"
			},
			{
				"command": "8th-wall-agent.explainCode",
				"title": "%command.explainCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "8th-wall-agent.fixCode",
				"title": "%command.fixCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "8th-wall-agent.improveCode",
				"title": "%command.improveCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "8th-wall-agent.addToContext",
				"title": "%command.addToContext.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "8th-wall-agent.newTask",
				"title": "%command.newTask.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "8th-wall-agent.focusChatInput",
				"title": "%command.focusInput.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "8th-wall-agent.acceptInput",
				"title": "%command.acceptInput.title%",
				"category": "%configuration.title%"
			}
		],
		"keybindings": [
			{
				"command": "8th-wall-agent.focusChatInput",
				"key": "ctrl+shift+a",
				"mac": "cmd+shift+a",
				"when": "true"
			}
		],
		"menus": {
			"editor/context": [
				{
					"submenu": "8th-wall-agent.contextMenu",
					"group": "navigation"
				}
			],
			"8th-wall-agent.contextMenu": [
				{
					"command": "8th-wall-agent.explainCode",
					"group": "1_actions@1"
				},
				{
					"command": "8th-wall-agent.fixCode",
					"group": "1_actions@2"
				},
				{
					"command": "8th-wall-agent.improveCode",
					"group": "1_actions@3"
				},
				{
					"command": "8th-wall-agent.addToContext",
					"group": "1_actions@4"
				}
			],
			"view/title": [
				{
					"command": "8th-wall-agent.settingsButtonClicked",
					"group": "navigation@1",
					"when": "view == 8th-wall-agent.SidebarProvider"
				},
				{
					"command": "8th-wall-agent.historyButtonClicked",
					"group": "navigation@2",
					"when": "view == 8th-wall-agent.SidebarProvider"
				},
				{
					"command": "8th-wall-agent.plusButtonClicked",
					"group": "navigation@3",
					"when": "view == 8th-wall-agent.SidebarProvider"
				}
			]
		},
		"submenus": [
			{
				"id": "8th-wall-agent.contextMenu",
				"label": "%views.contextMenu.label%"
			}
		],
		"codeActions": [
			{
				"languages": [
					"*"
				],
				"providedCodeActionKinds": [
					"vscode.CodeActionKind.QuickFix"
				]
			}
		]
	},
	"scripts": {
		"lint": "eslint . --ext=ts --max-warnings=0",
		"check-types": "tsc --noEmit",
		"pretest": "turbo run bundle --cwd ..",
		"test": "vitest run",
		"format": "prettier --write .",
		"bundle": "node esbuild.mjs",
		"vscode:prepublish": "pnpm bundle --production",
		"vsix": "mkdirp ../bin && vsce package --no-dependencies --out ../bin --allow-missing-repository",
		"publish:marketplace": "vsce publish --no-dependencies && ovsx publish --no-dependencies",
		"watch:bundle": "pnpm bundle --watch",
		"watch:tsc": "cd .. && tsc --noEmit --watch --project src/tsconfig.json",
		"clean": "rimraf README.md CHANGELOG.md LICENSE dist logs mock .turbo"
	},
	"dependencies": {
		"@anthropic-ai/bedrock-sdk": "^0.22.0",
		"@anthropic-ai/sdk": "^0.51.0",
		"@anthropic-ai/vertex-sdk": "^0.11.3",
		"@aws-sdk/client-bedrock-runtime": "^3.812.0",
		"@aws-sdk/credential-providers": "^3.806.0",
		"@cerebras/cerebras_cloud_sdk": "^1.35.0",
		"@google/genai": "^1.0.0",
		"@lmstudio/sdk": "^1.1.1",
		"@mistralai/mistralai": "^1.3.6",
		"@modelcontextprotocol/sdk": "^1.9.0",
		"@qdrant/js-client-rest": "^1.14.0",
		"@roo-code/cloud": "workspace:^",
		"@roo-code/ipc": "workspace:^",
		"@roo-code/telemetry": "workspace:^",
		"@roo-code/types": "workspace:^",
		"@types/lodash.debounce": "^4.0.9",
		"@vscode/codicons": "^0.0.36",
		"async-mutex": "^0.5.0",
		"axios": "^1.7.4",
		"cheerio": "^1.0.0",
		"chokidar": "^4.0.1",
		"clone-deep": "^4.0.1",
		"default-shell": "^2.2.0",
		"delay": "^6.0.0",
		"diff": "^5.2.0",
		"diff-match-patch": "^1.0.5",
		"eventsource-client": "^1.2.0",
		"eventsource-parser": "^3.0.6",
		"exceljs": "^4.4.0",
		"fast-deep-equal": "^3.1.3",
		"fast-xml-parser": "^5.0.0",
		"fastest-levenshtein": "^1.0.16",
		"fuse.js": "^7.1.0",
		"fzf": "^0.5.2",
		"get-folder-size": "^5.0.0",
		"google-auth-library": "^9.15.1",
		"gray-matter": "^4.0.3",
		"i18next": "^25.0.0",
		"ignore": "^7.0.3",
		"is-wsl": "^3.1.0",
		"isbinaryfile": "^5.0.2",
		"jwt-decode": "^4.0.0",
		"lodash.debounce": "^4.0.8",
		"lru-cache": "^11.1.0",
		"mammoth": "^1.9.1",
		"monaco-vscode-textmate-theme-converter": "^0.1.7",
		"node-cache": "^5.1.2",
		"node-ipc": "^12.0.0",
		"ollama": "^0.5.16",
		"openai": "^5.0.0",
		"os-name": "^6.0.0",
		"p-limit": "^6.2.0",
		"p-wait-for": "^5.0.2",
		"pdf-parse": "^1.1.1",
		"pkce-challenge": "^5.0.0",
		"pretty-bytes": "^7.0.0",
		"proper-lockfile": "^4.1.2",
		"ps-tree": "^1.2.0",
		"puppeteer-chromium-resolver": "^24.0.0",
		"puppeteer-core": "^23.4.0",
		"reconnecting-eventsource": "^1.6.4",
		"sanitize-filename": "^1.6.3",
		"say": "^0.16.0",
		"serialize-error": "^12.0.0",
		"simple-git": "^3.27.0",
		"sound-play": "^1.1.0",
		"stream-json": "^1.8.0",
		"string-similarity": "^4.0.4",
		"strip-ansi": "^7.1.0",
		"strip-bom": "^5.0.0",
		"tiktoken": "^1.0.21",
		"tmp": "^0.2.3",
		"tree-sitter-wasms": "^0.1.12",
		"turndown": "^7.2.0",
		"undici": "^7.13.0",
		"uri-js": "^4.4.1",
		"uuid": "^11.1.0",
		"vscode-material-icons": "^0.1.1",
		"web-tree-sitter": "^0.25.6",
		"workerpool": "^9.2.0",
		"ws": "^8.18.3",
		"yaml": "^2.8.0",
		"zod": "^3.25.61"
	},
	"devDependencies": {
		"@roo-code/build": "workspace:^",
		"@roo-code/config-eslint": "workspace:^",
		"@roo-code/config-typescript": "workspace:^",
		"@types/clone-deep": "^4.0.4",
		"@types/debug": "^4.1.12",
		"@types/diff": "^5.2.1",
		"@types/diff-match-patch": "^1.0.36",
		"@types/glob": "^8.1.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "20.x",
		"@types/node-cache": "^4.1.3",
		"@types/node-ipc": "^9.2.3",
		"@types/proper-lockfile": "^4.1.4",
		"@types/ps-tree": "^1.1.6",
		"@types/stream-json": "^1.7.8",
		"@types/string-similarity": "^4.0.2",
		"@types/tmp": "^0.2.6",
		"@types/turndown": "^5.0.5",
		"@types/vscode": "^1.84.0",
		"@types/ws": "^8.18.1",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/vsce": "3.3.2",
		"esbuild": "^0.25.0",
		"execa": "^9.5.2",
		"glob": "^11.0.1",
		"mkdirp": "^3.0.1",
		"nock": "^14.0.4",
		"npm-run-all2": "^8.0.1",
		"ovsx": "0.10.4",
		"rimraf": "^6.0.1",
		"tsup": "^8.4.0",
		"tsx": "^4.19.3",
		"typescript": "5.8.3",
		"vitest": "^3.2.3",
		"zod-to-ts": "^1.2.0"
	}
}
